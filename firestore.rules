rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===== 공통 헬퍼 =====
    function signedIn() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }
    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'dyrhl4321@gmail.com';
    }
    // 문서에 저장된 작성자(userId) 본인 여부
    function ownsDoc() {
      return request.auth != null && resource.data.userId == request.auth.uid;
    }

    // ===== 유저 프로필 (사진/닉네임 공개 읽기 필요) =====
    match /users/{userId} {
      allow read: if true;
      allow write: if isOwner(userId);

      // 머피월드 방명록 (싸이월드식) — 작성자=본인 서명, 삭제=방주인/작성자
      match /guestbook/{entryId} {
        allow read: if true;
        allow create: if signedIn() && request.resource.data.from == request.auth.uid;
        allow delete: if isOwner(userId) || (signedIn() && resource.data.from == request.auth.uid);
      }
      // 방 방문 카운터 (TODAY) — 방문자가 increment
      match /roomstat/{dayId} {
        allow read: if true;
        allow write: if signedIn();
      }
    }

    // ===== 피드 =====
    match /feed/{postId} {
      allow read: if true;
      allow create: if signedIn();
      // 좋아요/댓글수 등은 비작성자도 업데이트 → 로그인만 요구
      allow update: if signedIn();
      // 삭제는 작성자 본인 또는 관리자만
      allow delete: if ownsDoc() || isAdmin();

      match /comments/{commentId} {
        allow read: if true;
        allow create: if signedIn();
        allow delete: if ownsDoc() || isAdmin();
      }
    }

    // ===== 대숲 =====
    match /bamboo/{postId} {
      allow read: if true;
      allow create: if signedIn();
      allow update: if signedIn();        // 좋아요/저에요 신청/댓글수
      allow delete: if ownsDoc() || isAdmin();

      // 익명 댓글
      match /comments/{commentId} {
        allow read: if true;
        allow create: if signedIn();
        allow delete: if ownsDoc() || isAdmin();
      }
    }

    // ===== 좋아요(매칭 신청) =====
    match /likes/{likeId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.from == request.auth.uid;
      // 같은 사람에게 다시 눌러도 setDoc이 update로 판정됨 → 본인이 보낸 건만 허용(재전송 idempotent)
      allow update: if signedIn() && resource.data.from == request.auth.uid && request.resource.data.from == request.auth.uid;
      allow delete: if signedIn() && resource.data.from == request.auth.uid;
    }

    // ===== 매칭 =====
    match /matches/{matchId} {
      allow read: if signedIn();
      allow write: if signedIn();
    }

    // ===== 센터 체크인 (도감·스탬프) =====
    // 문서 ID = {uid}_{centerId}_{yyyymmdd} → 하루 1회가 ID로 자연 강제됨
    match /checkins/{checkinId} {
      allow read: if signedIn();                       // "우리센터 머피들" 표시용 공개 읽기(로그인)
      allow create: if signedIn()
                    && request.resource.data.uid == request.auth.uid
                    && checkinId.matches(request.auth.uid + '_.*');
      allow update: if signedIn() && resource.data.uid == request.auth.uid
                    && request.resource.data.uid == request.auth.uid;   // 스탬프 사진 추가용
      allow delete: if false;                          // 인증 기록은 삭제 불가(경제의 기반)
    }

    // ===== 크루 및 모든 서브컬렉션 =====
    match /crews/{crewId} {
      allow read: if true;
      allow create: if signedIn();
      allow update: if signedIn();        // 가입/멤버 변경/정보 수정
      allow delete: if signedIn();        // 크루 운영자 클라이언트 검증

      match /schedules/{scheduleId} {
        allow read: if true;
        allow write: if signedIn();

        match /applicants/{applicantId} {
          allow read: if signedIn();
          allow write: if signedIn();
        }
      }

      match /posts/{postId} {
        allow read: if true;
        allow create: if signedIn();
        allow update: if signedIn();
        allow delete: if ownsDoc() || isAdmin();

        match /comments/{commentId} {
          allow read: if true;
          allow create: if signedIn();
          allow delete: if ownsDoc() || isAdmin();
        }
      }

      match /photos/{photoId} {
        allow read: if true;
        allow create: if signedIn();
        allow delete: if ownsDoc() || isAdmin();
      }

      match /chat/{messageId} {
        allow read: if signedIn();
        allow create: if signedIn();
      }

      match /treasury/{entryId} {
        allow read: if signedIn();
        allow write: if signedIn();
      }

      match /feed/{postId} {
        allow read: if true;
        allow create: if signedIn();
        allow update: if signedIn();
        allow delete: if ownsDoc() || isAdmin();
      }
    }

    // ===== 즉석 스쿼드 (벙주 시스템) =====
    match /squads/{squadId} {
      allow read: if true;
      allow create: if signedIn() && request.resource.data.hostUid == request.auth.uid;
      // 참가 트랜잭션(memberUids)·출석코드·상태전이 — P0는 로그인 게이트, P2에서 Functions로 조임
      allow update: if signedIn();
      allow delete: if signedIn() && resource.data.hostUid == request.auth.uid;

      // 멤버 문서 = 본인 or 벙주(승인/입금 토글)
      match /members/{memberId} {
        allow read: if true;
        allow write: if signedIn() && (request.auth.uid == memberId
                     || get(/databases/$(database)/documents/squads/$(squadId)).data.hostUid == request.auth.uid);
      }

      // 스쿼드 톡 (sys 메시지는 uid=null 허용)
      match /chat/{msgId} {
        allow read: if true;
        allow create: if signedIn()
                      && request.resource.data.text is string
                      && request.resource.data.text.size() <= 200
                      && (request.resource.data.uid == request.auth.uid
                          || (request.resource.data.sys == true && request.resource.data.uid == null));
        allow update: if false;
        allow delete: if isAdmin();
      }
    }

    // ===== 센터 (헬스장) =====
    match /centers/{centerId} {
      allow read: if true;
      allow create: if signedIn();
      // 관리자 편집 + 별점 재계산(rating/reviews) 비소유자 업데이트 허용
      allow update: if signedIn();
      allow delete: if isAdmin();

      // 별점/리뷰 (문서 ID = 작성자 uid)
      match /ratings/{userId} {
        allow read: if true;
        allow write: if isOwner(userId);
      }
    }

    // ===== 센터 수다방 (도장 찍은 머피 전용 톡 — 자격은 클라이언트 게이트, 베타) =====
    match /centerTalk/{centerId}/msgs/{msgId} {
      allow read: if true;
      allow create: if signedIn()
                    && request.resource.data.uid == request.auth.uid
                    && request.resource.data.text is string
                    && request.resource.data.text.size() <= 200;
      allow update: if false;
      allow delete: if isAdmin() || (signedIn() && resource.data.uid == request.auth.uid);
    }

    // ===== 리뷰 신고 (관리자만 열람) =====
    match /reports/{reportId} {
      allow read: if isAdmin();
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    // ===== 센터 정보 수정 요청 (관리자만 열람) =====
    match /centerEditRequests/{reqId} {
      allow read: if isAdmin();
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    // ===== 알림 =====
    match /notifications/{notifId} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update: if signedIn();
      allow delete: if signedIn();
    }

    // ===== 1:1 채팅 =====
    match /chats/{chatId} {
      allow read, write: if signedIn();

      match /messages/{messageId} {
        allow read, write: if signedIn();
      }
    }
  }
}
